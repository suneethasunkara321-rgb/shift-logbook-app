
<!DOCTYPE html>
<html>
<head>
<title>Dashboard</title>
<link rel="stylesheet" href="/style.css">
</head>
<body>
<h2>Welcome <%= user.email %> (<%= user.role %>)</h2>
<a href="/logout">Logout</a>

<h3>Add Shift Log</h3>
<form method="POST" action="/add-log">
<select name="shift">
<option>Shift A</option>
<option>Shift B</option>
<option>Shift C</option>
<option>General Shift</option>
</select>
<input name="machine" placeholder="Machine">
<textarea name="work_done" placeholder="Work Done"></textarea>
<textarea name="issues" placeholder="Issues"></textarea>
<textarea name="actions" placeholder="Actions"></textarea>
<textarea name="suggestions" placeholder="Suggestions"></textarea>
<textarea name="remarks" placeholder="Remarks"></textarea>
<select name="status">
<option>Normal</option>
<option>Attention Required</option>
<option>Critical</option>
</select>
<button type="submit">Submit</button>
</form>

<h3>All Logs</h3>
<table border="1">
<tr><th>Date</th><th>Employee</th><th>Shift</th><th>Status</th></tr>
<% logs.forEach(log=>{ %>
<tr>
<td><%= log.created_at %></td>
<td><%= log.employee %></td>
<td><%= log.shift %></td>
<td><%= log.status %></td>
</tr>
<% }) %>
</table>
</body>
</html>
